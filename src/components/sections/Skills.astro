---
import { skills } from '../../data/skills';
---

<section id="skills" class="w-full px-4 py-5 sm:p-6 flex flex-col border border-primary rounded-[10px]">
  <h2 class="-translate-y-12 bg-[var(--background-color)] px-4 py-2 w-fit">
    Compétences
  </h2>

  <div
    class="w-full overflow-hidden"
    style="
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
      mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
    "
  >
    <ul class="flex flex-nowrap w-max list-none m-0 p-0 animate-carousel motion-reduce:animate-none">
      {skills.map((skill) => (
        <li class="pr-10 flex items-center justify-center text-[var(--text-color)] transition duration-200 hover:text-primary hover:scale-110">
          <div class="bg-[var(--secondary-background-color)] rounded-xl p-3 shadow-sm">
            <skill.icon width={44} height={44} />
          </div>
        </li>
      ))}
      {skills.map((skill) => (
        <li class="pr-10 flex items-center justify-center text-[var(--text-color)] transition duration-200 hover:text-primary hover:scale-110" aria-hidden="true">
          <div class="bg-[var(--secondary-background-color)] rounded-xl p-3 shadow-sm">
            <skill.icon width={44} height={44} />
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
