---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';

import '../styles.css';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Florent Perez" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image ?? '/profile.jpg'} />
    <meta property="og:type" content="website" />
    <slot name="head" />
  </head>
  <body>
    <!-- Scroll progress bar -->
    <div id="scroll-progress" role="progressbar" aria-hidden="true"></div>

    <Navbar />
    <main class="w-full max-w-[1200px] mx-auto px-4 sm:px-6 py-6 sm:py-10 flex flex-col gap-10 sm:gap-14 md:gap-16 min-w-0 overflow-x-hidden">
      <slot />
    </main>
    <Footer />
  </body>
  <script>
    // ── Scroll progress bar ──────────────────────────────────
    const bar = document.getElementById('scroll-progress') as HTMLElement;
    function updateProgress() {
      const s = document.documentElement;
      const pct = (s.scrollTop / (s.scrollHeight - s.clientHeight)) * 100;
      if (bar) bar.style.width = pct + '%';
    }
    window.addEventListener('scroll', updateProgress, { passive: true });

    // ── Section reveal ───────────────────────────────────────
    const revealObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            revealObs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => revealObs.observe(el));

    // ── Counter animation ────────────────────────────────────
    function animateCounter(el: Element) {
      const target = parseInt(el.getAttribute('data-target') || '0', 10);
      const suffix = el.getAttribute('data-suffix') || '';
      const dur = 900;
      const start = performance.now();
      function step(now: number) {
        const p = Math.min((now - start) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = Math.floor(eased * target) + suffix;
        if (p < 1) requestAnimationFrame(step);
        else {
          el.textContent = target + suffix;
          (el as HTMLElement).classList.add('popped');
          setTimeout(() => (el as HTMLElement).classList.remove('popped'), 500);
        }
      }
      requestAnimationFrame(step);
    }

    const counterObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            animateCounter(e.target);
            counterObs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.5 }
    );
    document.querySelectorAll('.counter-num').forEach((el) => counterObs.observe(el));

    // ── Terminal typewriter ──────────────────────────────────
    const lines = document.querySelectorAll<HTMLElement>('.t-line');
    lines.forEach((line, i) => {
      setTimeout(() => line.classList.add('show'), 300 + i * 280);
    });

    // ── Mouse parallax (pointer devices only — disabled on mobile) ─
    const heroEl = document.getElementById('hero') as HTMLElement | null;
    if (heroEl && window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
      heroEl.addEventListener('mousemove', (e: MouseEvent) => {
        const r = heroEl.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width  - 0.5) * 2;
        const y = ((e.clientY - r.top)  / r.height - 0.5) * 2;
        heroEl.style.setProperty('--mx', x.toFixed(3));
        heroEl.style.setProperty('--my', y.toFixed(3));
      }, { passive: true });
      heroEl.addEventListener('mouseleave', () => {
        heroEl.style.setProperty('--mx', '0');
        heroEl.style.setProperty('--my', '0');
      });
    }

    // ── Stagger reveal ───────────────────────────────────────
    const staggerObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            (e.target as HTMLElement)
              .querySelectorAll<HTMLElement>('.stagger-item')
              .forEach((item, i) => setTimeout(() => item.classList.add('visible'), i * 105));
            staggerObs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
    );
    document.querySelectorAll('.stagger-group').forEach((el) => staggerObs.observe(el));
  </script>
</html>
