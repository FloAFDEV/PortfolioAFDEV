---
const navLinks = [
  { label: 'Accueil',    href: '/' },
  { label: 'Expérience', href: '/#experience' },
  { label: 'Projets',    href: '/projects' },
  { label: 'À propos',   href: '/#about' },
  { label: 'Contact',    href: `mailto:contact@afdev.fr` },
];

const { pathname } = Astro.url;
---

<nav class="w-full sticky top-0 z-50 px-4 py-3">
  <div
    class="max-w-[1200px] mx-auto px-5 py-2 flex items-center justify-between gap-x-4 gap-y-2 flex-wrap min-w-0 w-full rounded-2xl"
    style="background: rgba(7,11,18,0.88); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(240,165,0,0.12); box-shadow: 0 4px 32px rgba(0,0,0,0.4), 0 0 0 1px rgba(240,165,0,0.04);"
  >
    <a
      href="/"
      class="flex items-center hover:opacity-90 transition-opacity duration-200 cursor-pointer"
      aria-label="FloAFDEV – Retour à l'accueil"
    >
      <img
        src="/logo-transparent.png"
        alt="Logo AFDEV"
        width="160"
        height="80"
        class="h-12 w-auto object-contain sm:h-14 md:h-16 logo-dark-bg"
        loading="eager"
      />
    </a>

    <ul class="flex flex-wrap gap-x-1 gap-y-1 list-none m-0 p-0" role="list">
      {navLinks.map(({ label, href }) => {
        const isActive =
          href === '/'
            ? pathname === '/'
            : !href.startsWith('mailto') && pathname.startsWith(href.split('#')[0]) && href !== '/';
        return (
          <li>
            <a
              href={href}
              class:list={[
                'text-sm no-underline px-3 py-1.5 rounded-lg transition-all duration-200 cursor-pointer font-medium',
                'hover:text-[#F0A500] hover:bg-[rgba(240,165,0,0.07)] focus-visible:outline-2 focus-visible:outline-[#F0A500] focus-visible:outline-offset-2',
                isActive
                  ? 'text-[#F0A500] bg-[rgba(240,165,0,0.1)]'
                  : 'text-[#94A3B8]',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</nav>
