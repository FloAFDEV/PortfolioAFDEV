---
const navLinks = [
  { label: 'Accueil',    href: '/' },
  { label: 'Expérience', href: '/#experience' },
  { label: 'Projets',    href: '/projects' },
  { label: 'À propos',   href: '/#about' },
  { label: 'Contact',    href: `mailto:afdevflo@gmail.com` },
];

const { pathname } = Astro.url;
---

<nav class="w-full sticky top-0 z-50 px-4 py-3">
  <div
    class="max-w-[1200px] mx-auto px-5 py-2.5 flex items-center justify-between gap-x-4 gap-y-2 flex-wrap min-w-0 w-full rounded-2xl"
    style="background: rgba(15,23,42,0.85); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 4px 24px rgba(0,0,0,0.3);"
  >
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center hover:opacity-80 transition-opacity duration-200 cursor-pointer"
      aria-label="FloAFDEV – Retour à l'accueil"
    >
      <img
        src="/logo-transparent.png"
        alt="Logo AFDEV"
        width="160"
        height="80"
        class="h-10 w-auto object-contain sm:h-12 md:h-14"
        style="filter: drop-shadow(0 0 6px rgba(34,197,94,0.4));"
        loading="eager"
      />
    </a>

    <!-- Links -->
    <ul class="flex flex-wrap gap-x-1 gap-y-2 list-none m-0 p-0" role="list">
      {navLinks.map(({ label, href }) => {
        const isActive =
          href === '/'
            ? pathname === '/'
            : !href.startsWith('mailto') && pathname.startsWith(href.split('#')[0]) && href !== '/';
        return (
          <li>
            <a
              href={href}
              class:list={[
                'text-sm no-underline px-3 py-1.5 rounded-lg transition-all duration-200 cursor-pointer font-medium',
                'hover:text-[#22C55E] hover:bg-white/5 focus-visible:outline-2 focus-visible:outline-[#22C55E] focus-visible:outline-offset-2',
                isActive
                  ? 'text-[#22C55E] bg-[rgba(34,197,94,0.1)]'
                  : 'text-[#94A3B8]',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</nav>
