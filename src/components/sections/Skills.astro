---
import { skills } from '../../data/skills';
---

<section id="skills" class="w-full p-4 flex flex-col border border-primary rounded-[10px]">
  <h2 class="-translate-y-12 bg-[var(--background-color)] px-4 py-2 w-fit">
    Compétences
  </h2>

  <div
    class="w-full overflow-x-auto"
    style="
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
      mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
    "
  >
    <ul class="flex flex-nowrap gap-8 list-none m-0 p-0 animate-carousel motion-reduce:animate-none">
      {skills.map((skill) => (
        <li class="text-white rounded transition duration-200 text-[0.9em] hover:text-primary hover:scale-110">
          <skill.icon width={48} height={48} />
        </li>
      ))}
      {skills.map((skill) => (
        <li class="text-white rounded transition duration-200 text-[0.9em] hover:text-primary hover:scale-110" aria-hidden="true">
          <skill.icon width={48} height={48} />
        </li>
      ))}
    </ul>
  </div>
</section>
