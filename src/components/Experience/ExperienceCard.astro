---
export interface ExperienceItem {
  position: string;
  company: string;
  duration: string;
  responsibilities: string[];
}

interface Props extends ExperienceItem {}
const { position, company, duration, responsibilities } = Astro.props;
---

<div>
  <h3 class="m-0 text-base font-semibold" style="color: #F0F2F7; font-family: 'Space Grotesk', sans-serif;">
    {position}
    <span class="font-normal" style="color: #F0A500;"> — {company}</span>
  </h3>
  <span
    class="inline-block text-[11px] font-medium mt-1.5 mb-3 px-2.5 py-0.5 rounded-full mono"
    style="background:rgba(240,165,0,0.07); color:var(--text-body); border:1px solid rgba(240,165,0,0.12);"
  >
    {duration}
  </span>
  <ul class="list-none m-0 p-0 flex flex-col gap-1.5">
    {responsibilities.map((p) => (
      <li class="flex items-start gap-2 text-sm" style="color:var(--text-body);">
        <svg class="flex-shrink-0 mt-1" xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#F0A500" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        {p}
      </li>
    ))}
  </ul>
</div>
