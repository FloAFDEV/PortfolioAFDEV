---
import { skills } from '../../data/skills';
---

<section id="skills" class="w-full glass-card px-6 py-8">
  <h2 class="section-title mb-8">Compétences</h2>

  <div
    class="w-full overflow-hidden"
    style="
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 12%, black 88%, transparent 100%);
      mask-image: linear-gradient(to right, transparent 0%, black 12%, black 88%, transparent 100%);
    "
  >
    <ul class="flex flex-nowrap w-max list-none m-0 p-0 animate-carousel motion-reduce:animate-none gap-4">
      {skills.map((skill) => (
        <li class="flex items-center justify-center transition-all duration-200 cursor-pointer hover:scale-110 group">
          <div
            class="rounded-xl p-3 transition-all duration-200 group-hover:border-[rgba(34,197,94,0.4)]"
            style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); color: #94A3B8;"
          >
            <div class="group-hover:text-[#22C55E] transition-colors duration-200" style="color: #94A3B8;">
              <skill.icon width={40} height={40} />
            </div>
          </div>
        </li>
      ))}
      {skills.map((skill) => (
        <li class="flex items-center justify-center transition-all duration-200 cursor-pointer hover:scale-110 group" aria-hidden="true">
          <div
            class="rounded-xl p-3 transition-all duration-200 group-hover:border-[rgba(34,197,94,0.4)]"
            style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); color: #94A3B8;"
          >
            <div class="group-hover:text-[#22C55E] transition-colors duration-200" style="color: #94A3B8;">
              <skill.icon width={40} height={40} />
            </div>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
