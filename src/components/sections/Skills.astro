---
import { skills } from '../../data/skills';
---

<section id="skills" class="w-full glass-card px-6 py-8 reveal">
  <h2 class="section-title mb-8">Compétences</h2>

  <div
    class="w-full overflow-hidden"
    style="
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
      mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    "
  >
    <ul class="flex flex-nowrap w-max list-none m-0 p-0 gap-4 animate-carousel motion-reduce:animate-none">
      {skills.map((skill) => (
        <li class="flex flex-col items-center gap-2 cursor-pointer group transition-all duration-200 hover:scale-110">
          <div
            class="rounded-xl p-3 transition-all duration-200"
            style="background: rgba(240,165,0,0.04); border: 1px solid rgba(240,165,0,0.08); color: #64748B;"
          >
            <div class="group-hover:[&>svg]:drop-shadow-none transition-all duration-200" style="color: #64748B;">
              <skill.icon width={40} height={40} />
            </div>
          </div>
        </li>
      ))}
      {skills.map((skill) => (
        <li class="flex flex-col items-center gap-2 cursor-pointer group transition-all duration-200 hover:scale-110" aria-hidden="true">
          <div
            class="rounded-xl p-3 transition-all duration-200"
            style="background: rgba(240,165,0,0.04); border: 1px solid rgba(240,165,0,0.08); color: #64748B;"
          >
            <div style="color: #64748B;">
              <skill.icon width={40} height={40} />
            </div>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
