---
import { socialMediaIcons } from '../../assets/social/util';
import { aboutMe } from '../../data/aboutMe';
---

<section id="about" class="w-full glass-card px-6 py-8 reveal">
  <h2 class="section-title mb-8">À propos de moi</h2>

  <article class="flex gap-8 w-full max-w-[900px] mx-auto flex-col md:flex-row md:items-start min-w-0">
    <!-- Profile + socials -->
    <div class="flex flex-col items-center gap-5 flex-shrink-0">
      <div
        class="overflow-hidden w-[155px] h-[155px]"
        style="border-radius: 18px; border: 2px solid rgba(240,165,0,0.25); box-shadow: 0 0 32px rgba(240,165,0,0.1), 0 0 0 6px rgba(240,165,0,0.04);"
      >
        <img
          src={aboutMe.profile.picture}
          alt={aboutMe.profile.altText}
          loading="lazy"
          width="155"
          height="155"
          class="w-full h-full object-cover"
        />
      </div>

      <div class="flex gap-3">
        {
          Object.entries(aboutMe.socialMedia).map(([key, value]) => {
            const IconComponent = socialMediaIcons[key as keyof typeof socialMediaIcons];
            return (
              <a
                href={value}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={key}
                class="cursor-pointer transition-all duration-200 rounded-xl p-2.5 hover:scale-110 hover:border-[rgba(240,165,0,0.4)]"
                style="background: rgba(240,165,0,0.05); color: #64748B; border: 1px solid rgba(240,165,0,0.1);"
              >
                <IconComponent width={26} height={26} />
              </a>
            );
          })
        }
      </div>

      <!-- Mini code card -->
      <div
        class="w-full text-[11px] rounded-lg p-3 mono"
        style="background: rgba(0,0,0,0.4); border: 1px solid rgba(240,165,0,0.1); color: #64748B; line-height: 1.7;"
      >
        <div><span style="color:#F0A500;">const</span> <span style="color:#93C5FD;">florent</span> = &#123;</div>
        <div>&nbsp;&nbsp;<span style="color:#FDA4AF;">city</span>: <span style="color:#86EFAC;">"France"</span>,</div>
        <div>&nbsp;&nbsp;<span style="color:#FDA4AF;">open</span>: <span style="color:#F0A500;">true</span>,</div>
        <div>&#125;;</div>
      </div>
    </div>

    <!-- Bio -->
    <div class="flex flex-col gap-4 min-w-0 flex-1">
      <h3 class="text-lg font-bold" style="color:#F0F2F7; font-family:'Space Grotesk',sans-serif;">
        {aboutMe.name}
      </h3>
      {
        aboutMe.bio.paragraphs.map((paragraph) => (
          <p class="text-sm leading-relaxed" style="color:var(--text-body);">
            {paragraph}
          </p>
        ))
      }

      {aboutMe.hobbies && aboutMe.hobbies.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-1">
          {aboutMe.hobbies.map((hobby) => (
            <span
              class="text-xs font-medium px-3 py-1 rounded-full mono"
              style="background: rgba(240,165,0,0.06); color: #F0A500; border: 1px solid rgba(240,165,0,0.18);"
            >
              {hobby}
            </span>
          ))}
        </div>
      )}
    </div>
  </article>
</section>
