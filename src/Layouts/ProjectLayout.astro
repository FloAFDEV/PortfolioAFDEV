---
import Layout from './Layout.astro';
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const canonicalUrl = new URL(`/projects/${project.slug}`, Astro.site ?? Astro.url.origin).href;
---

<Layout
  title={`${project.title} – Florent Perez`}
  description={project.shortDescription}
  image={project.thumbnail}
>
  <!-- Breadcrumb -->
  <nav aria-label="Fil d'ariane" class="flex items-center gap-2 text-xs mono" style="color: #475569;">
    <a href="/" class="hover:text-[#F0A500] transition-colors no-underline">Accueil</a>
    <span aria-hidden="true" style="color: #334155;">/</span>
    <a href="/projects" class="hover:text-[#F0A500] transition-colors no-underline">Projets</a>
    <span aria-hidden="true" style="color: #334155;">/</span>
    <span style="color: #F0A500;">{project.title}</span>
  </nav>

  <article class="flex flex-col gap-8">
    <!-- Hero -->
    <header class="flex flex-col gap-4 reveal">
      <div class="flex items-center gap-3 flex-wrap">
        <h1 class="text-2xl sm:text-3xl font-bold gradient-text">{project.title}</h1>
        {project.status === 'wip' && (
          <span
            class="text-xs font-bold uppercase tracking-wider px-2.5 py-1 rounded-full mono"
            style="background: rgba(240,165,0,0.1); color: #F0A500; border: 1px solid rgba(240,165,0,0.3);"
          >
            En cours
          </span>
        )}
      </div>
      <p class="text-sm sm:text-base max-w-[700px]" style="color:var(--text-body);">
        {project.shortDescription}
      </p>

      <!-- Tech tags -->
      <ul class="flex flex-wrap gap-2 list-none m-0 p-0 mono" aria-label="Technologies utilisées">
        {project.technologies.map((tech) => (
          <li
            class="text-xs font-medium px-3 py-1 rounded-full"
            style="background: rgba(240,165,0,0.07); color: #94A3B8; border: 1px solid rgba(240,165,0,0.18);"
          >
            {tech}
          </li>
        ))}
      </ul>

      <!-- CTA bar -->
      <div class="flex flex-wrap gap-3 items-center mt-1">
        {project.liveUrl && (
          <a
            href={project.liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            Voir le site en ligne
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        )}
        <a
          href="/projects"
          class="inline-flex items-center gap-2 text-sm no-underline transition-all duration-200 hover:text-[#F0A500] cursor-pointer"
          style="color: #475569;"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
          Retour aux projets
        </a>
      </div>
    </header>

    <!-- Thumbnail -->
    <div
      class="w-full overflow-hidden reveal"
      style="border-radius: 16px; border: 1px solid rgba(240,165,0,0.12); box-shadow: 0 0 40px rgba(240,165,0,0.04);"
    >
      <img
        src={project.thumbnail}
        alt={`Aperçu du projet ${project.title}`}
        width="800"
        height="450"
        loading="eager"
        class="w-full h-auto object-cover transition-transform duration-500 hover:scale-[1.01]"
      />
    </div>

    <!-- Description -->
    <section class="glass-card px-6 py-7 reveal">
      <h2 class="section-title mb-5">Description</h2>
      <div class="flex flex-col gap-3">
        {project.detailedDescription.map((para) => (
          <p class="text-sm leading-relaxed" style="color:var(--text-body);">{para}</p>
        ))}
      </div>
      <div
        class="mt-4 pt-4 text-xs mono flex items-center gap-2"
        style="border-top: 1px solid rgba(240,165,0,0.1); color: #475569;"
      >
        <span style="color: #F0A500;">$</span>
        <span><span style="color: #93C5FD;">role</span>: <span style="color: #86EFAC;">"{project.role}"</span></span>
      </div>
    </section>

    <!-- Screenshots -->
    {project.screenshots.length > 0 && (
      <section class="glass-card px-6 py-7 reveal">
        <h2 class="section-title mb-5">Captures d'écran</h2>
        <div class="grid gap-5 grid-cols-1 md:grid-cols-2">
          {project.screenshots.map((src, i) => (
            <div
              class="overflow-hidden"
              style="border-radius: 12px; border: 1px solid rgba(240,165,0,0.1);"
            >
              <img
                src={src}
                alt={`Capture d'écran ${i + 1} – ${project.title}`}
                width="800"
                height="450"
                loading="lazy"
                class="w-full h-auto object-cover transition-transform duration-400 hover:scale-[1.02]"
              />
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Challenges -->
    {project.challenges && project.challenges.length > 0 && (
      <section class="glass-card px-6 py-7 reveal">
        <h2 class="section-title mb-5">Défis &amp; Solutions</h2>
        <ul class="flex flex-col gap-5 list-none m-0 p-0">
          {project.challenges.map(({ problem, solution }) => (
            <li
              class="flex flex-col gap-2 p-4 rounded-xl"
              style="background: rgba(240,165,0,0.03); border: 1px solid rgba(240,165,0,0.08);"
            >
              <p class="text-[11px] font-bold uppercase tracking-widest mono" style="color: #F0A500;">// Défi</p>
              <p class="text-sm leading-relaxed" style="color:var(--text-body);">{problem}</p>
              <p class="text-[11px] font-bold uppercase tracking-widest mono mt-1" style="color: #86EFAC;">// Solution</p>
              <p class="text-sm leading-relaxed" style="color:var(--text-body);">{solution}</p>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>

  <link rel="canonical" href={canonicalUrl} slot="head" />
</Layout>
