---
import { skills } from '../../data/skills';
---

<section id="skills" class="w-full glass-card px-6 py-8 reveal">
  <h2 class="section-title mb-8">Compétences</h2>

  <div
    class="w-full overflow-hidden"
    style="
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
      mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    "
  >
    <ul class="flex flex-nowrap w-max list-none m-0 p-0 gap-3 animate-carousel motion-reduce:animate-none">
      {skills.map((skill) => (
        <li>
          <div class="skill-card">
            <div style="color:#7A8FAA; transition:color .2s;" class="group-hover:text-[#F0A500]">
              <skill.icon width={38} height={38} />
            </div>
            <span class="skill-name">{skill.name}</span>
          </div>
        </li>
      ))}
      {skills.map((skill) => (
        <li aria-hidden="true">
          <div class="skill-card">
            <div style="color:#7A8FAA;">
              <skill.icon width={38} height={38} />
            </div>
            <span class="skill-name">{skill.name}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
