---
import type { Project } from '../../data/projects';

interface Props extends Pick<Project, 'slug' | 'title' | 'shortDescription' | 'thumbnail' | 'technologies'> {}

const { slug, title, shortDescription, thumbnail, technologies } = Astro.props;
---

<article class="flex flex-col h-full rounded-[10px] bg-[var(--secondary-background-color)] shadow-[0_2px_4px_rgba(0,0,0,0.1)] overflow-hidden transition-transform duration-300 hover:-translate-y-[5px]">
  <div class="overflow-hidden">
    <img
      src={thumbnail}
      alt={`Aperçu du projet ${title}`}
      loading="lazy"
      width="400"
      height="225"
      class="w-full h-[180px] object-cover transition-transform duration-500 hover:scale-105"
    />
  </div>

  <div class="flex flex-col flex-1 p-4 gap-3">
    <h3 class="text-[1.2em] font-semibold">{title}</h3>

    <p class="text-sm text-[var(--text-color)] opacity-80 flex-1 leading-relaxed">
      {shortDescription}
    </p>

    <!-- Tech tags -->
    <ul class="flex flex-wrap gap-1.5 list-none m-0 p-0" aria-label="Technologies">
      {technologies.map((tech) => (
        <li class="bg-primary/15 text-primary text-xs px-2 py-0.5 rounded-full border border-primary/30">
          {tech}
        </li>
      ))}
    </ul>

    <a
      href={`/projects/${slug}`}
      class="mt-1 inline-flex items-center gap-1.5 text-sm text-primary font-semibold no-underline hover:underline focus-visible:outline-2 focus-visible:outline-primary rounded"
      aria-label={`Voir les détails du projet ${title}`}
    >
      Voir le détail
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    </a>
  </div>
</article>
