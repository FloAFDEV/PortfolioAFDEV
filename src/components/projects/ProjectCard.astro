---
import type { Project } from '../../data/projects';

interface Props extends Pick<Project, 'slug' | 'title' | 'shortDescription' | 'thumbnail' | 'technologies' | 'status'> {}

const { slug, title, shortDescription, thumbnail, technologies, status } = Astro.props;
---

<article
  class="relative flex flex-col h-full w-full min-w-0 overflow-hidden cursor-pointer group transition-all duration-300 hover:-translate-y-1.5"
  style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; box-shadow: 0 2px 16px rgba(0,0,0,0.3);"
>
  {status === 'wip' && (
    <div
      class="absolute top-3 right-3 z-10 text-[10px] font-bold uppercase tracking-wider px-2.5 py-0.5 rounded-full mono"
      style="background: rgba(240,165,0,0.12); color: #F0A500; border: 1px solid rgba(240,165,0,0.3);"
    >
      En cours
    </div>
  )}

  <!-- Thumbnail -->
  <div class="overflow-hidden relative" style="height: 185px;">
    <img
      src={thumbnail}
      alt={`Aperçu du projet ${title}`}
      loading="lazy"
      width="400"
      height="185"
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    <!-- Gold shimmer overlay on hover -->
    <div
      class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
      style="background: linear-gradient(135deg, rgba(240,165,0,0.08) 0%, transparent 60%);"
      aria-hidden="true"
    ></div>
  </div>

  <!-- Gold top border reveal on hover -->
  <div
    class="absolute top-0 left-0 right-0 h-[2px] opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
    style="background: linear-gradient(to right, transparent, #F0A500, transparent);"
    aria-hidden="true"
  ></div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5 gap-3">
    <h3
      class="text-base font-semibold transition-colors duration-200 group-hover:text-[#F0A500]"
      style="color: #EDEFF4; font-family: 'Space Grotesk', sans-serif;"
    >
      {title}
    </h3>

    <p class="text-sm leading-relaxed flex-1" style="color: #64748B;">
      {shortDescription}
    </p>

    <!-- Tech tags -->
    <ul class="flex flex-wrap gap-1.5 list-none m-0 p-0 mono" aria-label="Technologies">
      {technologies.map((tech) => (
        <li
          class="text-[11px] px-2 py-0.5 rounded-full font-medium"
          style="background: rgba(240,165,0,0.06); color: #94A3B8; border: 1px solid rgba(240,165,0,0.15);"
        >
          {tech}
        </li>
      ))}
    </ul>

    <a
      href={`/projects/${slug}`}
      class="mt-1 inline-flex items-center gap-1.5 text-sm font-semibold no-underline focus-visible:outline-2 rounded transition-all duration-200 group-hover:gap-2.5"
      style="color: #F0A500; font-family: 'Space Grotesk', sans-serif;"
      aria-label={`Voir les détails du projet ${title}`}
    >
      Voir le détail
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    </a>
  </div>
</article>
